{
  "name": "disclosurediff-mcp",
  "version": "0.1.0",
  "description": "MCP server that diffs SEC disclosures year-over-year and grounds claims with mandatory EDGAR citations",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "disclosurediff-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "start:stdio": "TRANSPORT=stdio node dist/index.js",
    "start:http": "TRANSPORT=http node dist/index.js",
    "test": "tsx --test src/**/*.test.ts",
    "eval": "tsx evals/harness.ts",
    "eval:live": "EVAL_LIVE=1 tsx evals/harness.ts",
    "spike": "tsx scripts/spike-item1a.ts",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "sec",
    "edgar",
    "finance",
    "disclosure",
    "citations"
  ],
  "author": "Suba Sah <sah.suba@gmail.com>",
  "mcpName": "io.github.subasah/disclosurediff-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/subasah/disclosurediff-mcp.git"
  },
  "homepage": "https://subasah.github.io/disclosurediff-mcp/",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
